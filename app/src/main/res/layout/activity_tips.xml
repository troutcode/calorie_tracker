<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TipsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nutrition Tips"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvTipsGoalLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#888780"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvTip1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:textSize="14sp"
            android:textColor="#1A1A2E"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvTip2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:textSize="14sp"
            android:textColor="#1A1A2E"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvTip3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:textSize="14sp"
            android:textColor="#1A1A2E"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvTip4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EAF3DE"
            android:padding="16dp"
            android:textSize="14sp"
            android:textColor="#27500A"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvTip5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E1F5EE"
            android:padding="16dp"
            android:textSize="14sp"
            android:textColor="#085041"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnBackTips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Home"
            android:backgroundTint="#E0E7FF"
            android:textColor="#4F46E5"/>

    </LinearLayout>
</ScrollView>