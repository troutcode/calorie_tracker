<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    tools:context=".ProfileActivity">

    <AbsoluteLayout
        android:layout_width="match_parent"
        android:layout_height="820dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/profile_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_x="32dp"
            android:layout_y="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/profile_subtitle"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_x="32dp"
            android:layout_y="62dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_age"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_x="32dp"
            android:layout_y="105dp"/>
        <EditText
            android:id="@+id/etAge"
            android:layout_width="311dp"
            android:layout_height="48dp"
            android:hint="@string/hint_age"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:inputType="number"
            android:textColor="@color/text_primary"
            android:layout_x="32dp"
            android:layout_y="125dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_weight"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_x="32dp"
            android:layout_y="190dp"/>
        <EditText
            android:id="@+id/etWeight"
            android:layout_width="311dp"
            android:layout_height="48dp"
            android:hint="@string/hint_weight"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:layout_x="32dp"
            android:layout_y="210dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_height"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_x="32dp"
            android:layout_y="275dp"/>
        <EditText
            android:id="@+id/etHeight"
            android:layout_width="311dp"
            android:layout_height="48dp"
            android:hint="@string/hint_height"
            android:background="@drawable/input_bg"
            android:padding="12dp"
            android:inputType="number"
            android:textColor="@color/text_primary"
            android:layout_x="32dp"
            android:layout_y="295dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_gender"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_x="32dp"
            android:layout_y="360dp"/>
        <Spinner
            android:id="@+id/spGender"
            android:layout_width="311dp"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:padding="8dp"
            android:entries="@array/gender_options"
            android:layout_x="32dp"
            android:layout_y="380dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_activity"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_x="32dp"
            android:layout_y="445dp"/>
        <Spinner
            android:id="@+id/spActivity"
            android:layout_width="311dp"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:padding="8dp"
            android:entries="@array/activity_options"
            android:layout_x="32dp"
            android:layout_y="465dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_goal"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_x="32dp"
            android:layout_y="530dp"/>
        <Spinner
            android:id="@+id/spGoal"
            android:layout_width="311dp"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:padding="8dp"
            android:entries="@array/goal_options"
            android:layout_x="32dp"
            android:layout_y="550dp"/>

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="311dp"
            android:layout_height="50dp"
            android:text="@string/btn_save_profile"
            android:backgroundTint="@color/accent_purple"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_x="32dp"
            android:layout_y="630dp"/>

    </AbsoluteLayout>

</ScrollView>